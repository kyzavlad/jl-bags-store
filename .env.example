# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Sheets CSV export URL used by the import/sync feature
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/XXXX/export?format=csv&gid=0

# Public pricelist access key (the ?key= value on /pricelist)
PRICELIST_KEY=jlprice2026

# Public site URL (used for absolute links / metadata)
NEXT_PUBLIC_SITE_URL=https://jl-bags-store.vercel.app

# Optional: n8n webhook for order/automation notifications
N8N_WEBHOOK_URL=

# Analytics — all optional; site works without these
# GA4 Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Google Ads conversion action send_to — full value incl. label, e.g.
# AW-123456789/AbCdEfGhIjKlMnOp. Fires conversions for phone/telegram/viber
# clicks. The account ID (AW-...) is derived from the part before the "/".
# Leave empty to disable Google Ads conversion tracking entirely.
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_SEND_TO=
# Meta Pixel ID (numeric)
NEXT_PUBLIC_META_PIXEL_ID=
